{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "GovernanceDatasetFacet",
    "type": "object",
    "required": [
        "_producer",
        "_schemaURL"
    ],
    "properties": {
        "_producer": {
            "type": "string",
            "format": "uri"
        },
        "_schemaURL": {
            "type": "string",
            "format": "uri"
        },
        "title": {
            "type": [
                "string",
                "null"
            ]
        },
        "description": {
            "type": [
                "string",
                "null"
            ]
        },
        "accessLevel": {
            "type": [
                "string",
                "null"
            ],
            "enum": [
                "open",
                "internal",
                "restricted"
            ],
            "description": "Dataset access level for policy enforcement"
        },
        "attribution": {
            "type": [
                "string",
                "null"
            ],
            "description": "Mandatory attribution text required by data license"
        },
        "accessRequirements": {
            "type": [
                "string",
                "null"
            ],
            "enum": [
                "all",
                "partner",
                "contract"
            ],
            "description": "Preconditions required to access this dataset"
        },
        "classification": {
            "type": [
                "string",
                "null"
            ],
            "enum": [
                "pii",
                "red",
                "yellow",
                "green"
            ],
            "description": "Data classification level"
        },
        "retentionDays": {
            "type": [
                "integer",
                "null"
            ],
            "description": "Data retention period in days"
        },
        "license": {
            "type": [
                "string",
                "null"
            ],
            "description": "License identifier or URL"
        },
        "sourceSystem": {
            "type": [
                "string",
                "null"
            ],
            "description": "Source system that produced this dataset"
        },
        "owners": {
            "type": [
                "array",
                "null"
            ],
            "items": {
                "type": "string"
            },
            "description": "List of owners in format 'group:/path' or 'user:sub'"
        },
        "rowFilters": {
            "type": "array",
            "items": {
                "type": "object",
                "required": ["handler"],
                "properties": {
                    "handler": { "type": "string" },
                    "args": { "type": "object" }
                }
            },
            "description": "Row filter specs [{handler, args}] for row-level access control"
        },
        "medallion": {
            "type": ["string", "null"],
            "enum": ["bronze", "silver", "gold", null],
            "description": "Data quality tier"
        },
        "contractRequired": {
            "type": "boolean",
            "description": "Require a signed contract before data access"
        },
        "consentRequired": {
            "type": "boolean",
            "description": "Require per-subject consent; triggers consent constraint in ODRL offer"
        },
        "odrlAction": {
            "type": "string",
            "description": "Primary ODRL action granted (e.g. use, distribute)"
        },
        "purpose": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Permitted usage purposes (ODRL purpose constraints)"
        }
    }
}