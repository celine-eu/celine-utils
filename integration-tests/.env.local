# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=securepassword123
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=15432

OPENLINEAGE_URL=http://host.docker.internal:5003

LOG_LEVEL=debug
CELINE_LOG_LEVEL=debug

# MQTT Pipeline Events
MQTT_EVENTS_ENABLED=true

# MQTT Broker (via celine-sdk)
CELINE_MQTT_HOST=host.docker.internal
CELINE_MQTT_PORT=1883
CELINE_MQTT_USE_TLS=false

# OIDC Authentication (optional - for JWT auth to broker)
CELINE_OIDC_BASE_URL=http://keycloak.celine.localhost/realms/celine
CELINE_OIDC_CLIENT_ID=celine-cli
CELINE_OIDC_CLIENT_SECRET=celine-cli
